{
  "getTicket": {
    "schema": {
      "method": "GET",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "getConversations": {
    "schema": {
      "method": "GET",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>/conversations",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "forwardTicket": {
    "schema": {
      "method": "POST",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>/forward",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  },
  "createDraft": {
    "schema": {
      "method": "POST",
      "host": "<%= iparam.freshdesk_domain %>",
      "path": "/api/v2/tickets/<%= context.ticket_id %>/reply_draft",
      "headers": {
        "Authorization": "Basic <%= context.auth_token %>",
        "Content-Type": "application/json"
      }
    }
  }
}
